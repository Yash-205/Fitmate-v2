{
  /* 
    APPLICATION CONFIGURATION
    This configures how your frontend source code (the code that runs in the browser) 
    is handled by TypeScript.
  */
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"], // browser-specific libraries
    "module": "esnext",
    "types": ["vite/client"], // types for Vite-specific features like import.meta
    "skipLibCheck": true,

    /* Bundler mode - Optimized for modern bundlers like Vite */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true, // Vite handles the actual build/emit
    "jsx": "react-jsx", // Support for React 17+ JSX transform
    
    /* Strict Type Checking & Linting */
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"] // Only look at files in the src directory
}
